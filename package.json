{
  "name": "tianji",
  "private": true,
  "version": "1.32.11",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others npm:dev:server npm:dev:web",
    "dev:web": "cd src/client && pnpm dev",
    "dev:server": "cd src/server && pnpm dev",
    "start": "cd src/server && cross-env NODE_ENV=production node ./dist/src/server/main.js",
    "start:docker": "pnpm start:docker:db && pnpm start",
    "start:docker:db": "cd src/server && pnpm db:migrate:apply && pnpm ch:migrate:apply",
    "website": "cd website && pnpm dev",
    "example": "cd example/web && pnpm dev",
    "storybook": "cd src/client && pnpm storybook",
    "test": "vitest",
    "build": "pnpm build:tracker && pnpm build:app && pnpm build:geo",
    "build:static": "pnpm build:tracker && pnpm build:client && pnpm build:geo",
    "build:app": "pnpm build:server && pnpm build:client",
    "build:client": "cd src/client && pnpm build",
    "build:server": "cd src/server && pnpm build",
    "build:tracker": "tsx scripts/build-tracker.ts",
    "build:geo": "tsx scripts/build-geo.ts",
    "build:llm": "tsx scripts/fetch-llm-model.ts && tsx scripts/fetch-llm-model-v2.ts",
    "build:openapi": "tsx --tsconfig ./tsconfig.base.json ./scripts/build-openapi-schema.ts && cd packages/client-sdk && pnpm generate:client",
    "check:type": "pnpm -r check:type",
    "release": "release-it",
    "release:patch": "release-it -i patch",
    "release:apps": "pnpm -r --filter \"./apps/*\" publish --registry=https://registry.npmjs.com/",
    "release:packages": "pnpm -r --filter \"./packages/*\" publish --registry=https://registry.npmjs.com/"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "9.0.3",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^18.19.80",
    "@types/tar": "^6.1.13",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.3.0",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "release-it": "17.10.0",
    "tar": "^6.2.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "5.7.2",
    "vite": "^5.4.14"
  },
  "dependencies": {
    "dayjs": "1.11.10",
    "eventemitter-strict": "^1.0.1",
    "zod": "4.1.12"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "overrides": {
      "@auth/core": "0.34.3",
      "react": "18.2.0",
      "react-dom": "18.2.0",
      "@types/node": "22.13.11",
      "@types/react": "18.2.78",
      "@types/react-dom": "18.2.21",
      "dayjs": "1.11.10",
      "esbuild": "0.28.1",
      "monaco-editor": "0.53.0",
      "postman-code-generators": "1.8.0",
      "cross-spawn": "7.0.6",
      "@types/cross-spawn": "6.0.6",
      "tar-fs@2": "2.1.4",
      "tar-fs@3": "3.1.1",
      "form-data@2": "2.5.6",
      "form-data@3": "3.0.5",
      "form-data@4": "4.0.6",
      "basic-ftp": "5.3.1",
      "defu": "6.1.5",
      "glob@10": "10.5.0",
      "h3": "1.15.6",
      "jws@3": "3.2.3",
      "lodash": "4.18.0",
      "minimatch@3": "3.1.4",
      "minimatch@5": "5.1.8",
      "minimatch@9": "9.0.7",
      "path-to-regexp@0.1": "0.1.13",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4",
      "shell-quote": "1.8.4",
      "socket.io-parser": "4.2.6",
      "tar@7": "7.5.11",
      "validator": "13.15.22",
      "ws@7": "7.5.11",
      "ws@8": "8.21.0",
      "typescript": "5.7.2",
      "zod": "4.1.12",
      "@i18next-toolkit/cli>zod": "3.25.76",
      "zod-openapi": "5.4.3"
    },
    "patchedDependencies": {
      "zod-prisma@0.5.4": "patches/zod-prisma@0.5.4.patch",
      "@docusaurus/plugin-sitemap@3.7.0": "patches/@docusaurus__plugin-sitemap.patch"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "@swc/core",
      "es5-ext",
      "esbuild",
      "isolated-vm",
      "msw",
      "prisma",
      "puppeteer",
      "sharp",
      "zeromq"
    ]
  }
}
